# Template only — DO NOT commit a filled-in copy of this file. Apply via
# your secrets manager (Vault, Sealed Secrets, External Secrets Operator,
# `kubectl create secret` from a CI secret store, etc.), never from a
# plaintext file checked into git.
apiVersion: v1
kind: Secret
metadata:
  name: agenticframework-secrets
  namespace: tenant-{{TENANT_ID}}
type: Opaque
stringData:
  # This tenant's OWN Postgres instance — infrastructure-level budget
  # isolation per §30, not a connection string shared with other tenants.
  DATABASE_URL: "postgresql://REPLACE_ME"
  ANTHROPIC_API_KEY: "REPLACE_ME"
  OPENAI_API_KEY: "REPLACE_ME"
  AGENT_OWNER_ID: "REPLACE_ME"
