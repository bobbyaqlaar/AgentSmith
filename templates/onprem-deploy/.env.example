# On-premise deployment config — strictly env-var-driven, no cloud secret
# manager dependency (see README.md "the contract"). Copy to .env.

# ── App images (built by cd-staging.yml/cd-production.yml's build-push-ghcr
# step, or any image you build yourself) ────────────────────────────────────
APP_IMAGE_PROD=ghcr.io/your-org/your-app:latest
# Leave empty to run prod-only with no canary/shadow routing.
APP_IMAGE_CANARY=
APP_IMAGE_SHADOW=

# Port your app's container listens on internally (must serve GET /healthz).
APP_PORT=8080

# ── Traffic shaping ──────────────────────────────────────────────────────────
PROXY_ENGINE=traefik          # traefik | envoy
PROXY_LISTEN_PORT=80
CANARY_WEIGHT_PERCENT=10      # % of live traffic to app-canary; rest to app-prod
SHADOW_MIRROR_PERCENT=100     # % of live traffic mirrored (fire-and-forget) to app-shadow

# ── State layer (optional — set WITH_DB=true to enable the db service) ──────
WITH_DB=false
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=app

# ── Whatever your app itself needs — add below, read only from env at
# runtime (no AWS/GCP secret manager calls; see README.md point 3) ──────────
# AGENT_PROVIDER_API_KEY=
# AGENT_MONTHLY_USD_CAP=
