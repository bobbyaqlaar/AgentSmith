# templates/uae-sovereign/env.example — merge into tenant secrets / .env
# DO NOT commit real keys. All hosts below must be in-border for national data.

# ── Mode: stay local for sovereign profile ───────────────────────────────────
AI_STACK_MODE=local

# ── Pattern A — UAE-hosted Ollama + Falcon 3 (default in models.yaml) ────────
# No /v1 suffix; models.yaml adds /v1. Live-verified 2026-07-10:
#   falcon3:3b, falcon3:1b via local Ollama chat completions.
# Pull: ollama pull falcon3:3b && ollama pull falcon3:1b
# Smoke: OLLAMA_BASE_URL=http://127.0.0.1:11434 python3 scripts/verify_sovereign_endpoint.py
OLLAMA_BASE_URL=http://ollama.uae.internal:11434

# Optional: pin judge model role used by eval scripts
AGENT_JUDGE_MODEL=falcon3:1b

# ── Pattern B — sovereign OpenAI-compatible API (optional) ───────────────────
# UAE_SOVEREIGN_API_BASE=https://api.sovereign-provider.ae/v1
# UAE_SOVEREIGN_API_KEY=
# UAE_SOVEREIGN_MODEL_ID=

# ── Pattern C — Hugging Face (optional weight pull / research) ───────────────
# Public HF is NOT UAE residency. Router does not host the TII ids below.
# HF_TOKEN=
# HF_BASE_URL=https://router.huggingface.co/v1

# ── In-border data plane ─────────────────────────────────────────────────────
# Postgres (portal, budget, DLQ, audit) — UAE region or on-prem
DATABASE_URL=postgresql://user:pass@postgres.uae.internal:5432/agenticframework

# Phoenix / OTLP — must not leave the residency boundary
AGENT_PHOENIX_ENDPOINT=http://phoenix.uae.internal:6006
OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix.uae.internal:6006/v1/traces

# HITL blobs — local path or in-border object storage
HITL_ENCRYPTION_KEY=
HITL_BLOB_DIR=/var/agentsmith/hitl
# HITL_BLOB_S3_BUCKET=  # only if bucket is UAE/on-prem equivalent

# Audit (Ops Portal)
AUDIT_LOG_HMAC_KEY=
AUDIT_LOG_WRITE_TOKEN=
OPS_PORTAL_URL=https://ops.uae.internal

# Identity
AGENT_OWNER_ID=
AGENT_OWNER_NAME=

# Budget — prefer postgres backend when DATABASE_URL is set
BUDGET_BACKEND=postgres
AGENT_MONTHLY_USD_CAP=50

# Eval gates (run-evals.py suites)
# Fairness eval gate (run-evals.py --suite fairness)
FAIRNESS_FAIL_BELOW=0.80
# FAIRNESS_EVALS=required   # optional: hard-fail in CI when set as repo variable

# Hallucination eval gate (run-evals.py --suite hallucination)
HALLUCINATION_FAIL_ABOVE=0.05

# TTFT live gate (scripts/verify_ttft.py — Ollama streaming)
TTFT_FAIL_ABOVE_MS=2000
# TTFT_LIVE=required  # repo variable — enable live Ollama job

# Trace redaction — use staging or production profile in non-dev
# (see runtime/trace_redactor.py / OPERATIONS.md)
# REDACTION_PROFILE=production
