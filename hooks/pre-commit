#!/usr/bin/env bash
# AgenticFramework: pre-commit guardrail
# Blocks unresolved AI markers, empty catch blocks, and unsafe Go patterns.

if [ "${DISABLE_AI_STACK:-false}" = "true" ]; then exit 0; fi

FAILED=0
STAGED=$(git diff --cached --name-only --diff-filter=d 2>/dev/null)
[ -z "$STAGED" ] && exit 0

echo "🚨 AgenticFramework: Running pre-commit guardrails..."

# ── Guardrail 1: Unresolved AI shortcut markers ──────────────────────────────
if echo "$STAGED" | xargs grep -E -I -l "(ponytail:|TODO: agent|@agent-ignore)" /dev/null 2>/dev/null | grep -q .; then
  echo "$STAGED" | xargs grep -E -I -n "(ponytail:|TODO: agent|@agent-ignore)" /dev/null 2>/dev/null || true
  echo "❌ ERROR: Commit blocked. Unresolved AI marker found (ponytail: / TODO: agent / @agent-ignore)."
  echo "   Resolve the marker before committing."
  FAILED=1
fi

# ── Guardrail 2: Empty catch/except blocks ────────────────────────────────────
while IFS= read -r file; do
  case "$file" in
    *.ts|*.tsx|*.js|*.jsx)
      if grep -E -n "catch\s*\([^)]*\)\s*\{\s*\}" "$file" 2>/dev/null; then
        echo "❌ ERROR ($file): Empty catch block. Swallowing errors is a safety violation."
        FAILED=1
      fi
      ;;
    *.py)
      if grep -E -n "except\s*(\w+)?:\s*$" "$file" 2>/dev/null | grep -v "#" | grep -q .; then
        echo "❌ ERROR ($file): Bare except clause with no handler body. Log or re-raise all exceptions."
        FAILED=1
      fi
      ;;
    *.go)
      if grep -E -n "^[[:space:]]*_\s*,\s*_\s*:?=" "$file" 2>/dev/null; then
        echo "❌ ERROR ($file): Double blank identifier. Idiomatic Go forbids ignoring both return values."
        FAILED=1
      fi
      ;;
  esac
done <<< "$STAGED"

# ── Guardrail 3: direct cost_router imports in runtime/ (enterprise mode) ────
# SPECS.md line 1618: "workers MUST NOT import cost_router.py directly" — that
# rule previously existed only as a comment in runtime/llm_gateway.py and
# runtime/worker.py, with nothing actually enforcing it (FIXES_AND_CLEANUP.md
# 1.3). Any call routed through cost_router.py bypasses the per-tenant budget
# store, degrade ladder, and audit trail entirely. Enterprise mode = an org
# policy file exists at ~/.agent-framework/agenticframework-org.yaml.
ORG_POLICY_FILE="$HOME/.agent-framework/agenticframework-org.yaml"
if [ -f "$ORG_POLICY_FILE" ]; then
  while IFS= read -r file; do
    case "$file" in
      runtime/*.py)
        if grep -E -n "^[[:space:]]*(import[[:space:]]+cost_router|from[[:space:]]+(scripts\.)?cost_router[[:space:]]+import|from[[:space:]]+scripts[[:space:]]+import[[:space:]]+cost_router)" "$file" 2>/dev/null; then
          echo "❌ ERROR ($file): direct cost_router import inside runtime/. Workers MUST go through"
          echo "   runtime/llm_gateway.py — importing cost_router.py directly bypasses budget"
          echo "   enforcement, the degrade ladder, and the audit trail entirely (SPECS.md line 1618)."
          FAILED=1
        fi
        ;;
    esac
  done <<< "$STAGED"
fi

if [ "$FAILED" -ne 0 ]; then
  echo "────────────────────────────────────────────────"
  echo "🛑 Pre-commit guardrail failed. Fix issues above."
  echo "   Bypass (emergency only): DISABLE_AI_STACK=true git commit"
  exit 1
fi

echo "✅ Pre-commit guardrails passed."
exit 0
