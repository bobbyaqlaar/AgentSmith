#!/usr/bin/env bash
# AgentSmith: post-checkout
# Provisions IDE rules, Antigravity skills, CI workflows, Knowledge Graph.
# Fires on: git init, git checkout, git clone

if [ "${DISABLE_AI_STACK:-false}" = "true" ]; then exit 0; fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
[ -z "$REPO_ROOT" ] && exit 0

# ── Developer opt-in gate for PRE-EXISTING repos (SPECS.md §7) ────────────────
# Global init.templateDir installs these hooks into every repo on the
# machine, including a third-party project someone just `git clone`'d. A
# repo that already has commit history and has never opted in is not ours
# to provision — writing .cursorrules/CI workflows/.gitignore entries into
# it would pollute someone else's project. A brand-new `git init` (no HEAD
# yet) or an already-opted-in repo (.agenticframework/ marker or
# tenant.yaml, possibly committed) provisions normally.
if git rev-parse --verify HEAD >/dev/null 2>&1 \
   && [ ! -f "$REPO_ROOT/.agenticframework/enabled" ] \
   && [ ! -f "$REPO_ROOT/.agenticframework/tenant.yaml" ]; then
  echo "ℹ️  AgentSmith: existing repo, not opted in — skipping provisioning."
  echo "   To opt in: mkdir -p .agenticframework && touch .agenticframework/enabled, then run: git checkout ."
  exit 0
fi

FRAMEWORK_DIR="$HOME/.agent-framework"
SCRIPTS_DIR="$FRAMEWORK_DIR/scripts"

# ── Detect stack ──────────────────────────────────────────────────────────────
STACK="GENERIC"
TEST_CMD="echo 'No test command configured'"

if [ -f "$REPO_ROOT/package.json" ]; then
  STACK="TS_REACT"; TEST_CMD="npm test -- --watchAll=false --ci"
elif [ -f "$REPO_ROOT/requirements.txt" ] || [ -f "$REPO_ROOT/pyproject.toml" ] || [ -f "$REPO_ROOT/Pipfile" ]; then
  STACK="PYTHON_FASTAPI"; TEST_CMD="pytest"
elif [ -f "$REPO_ROOT/go.mod" ]; then
  STACK="GO"; TEST_CMD="go test -race ./..."
fi

echo "🔧 AgentSmith: Detected stack [$STACK]"

# ── Create .agent-rfc/ structure ─────────────────────────────────────────────
mkdir -p "$REPO_ROOT/.agent-rfc/fixtures"

# ── Seed golden dataset from framework base ───────────────────────────────────
GOLDEN_FILE="$REPO_ROOT/.agent-rfc/fixtures/golden_evals.json"
if [ ! -f "$GOLDEN_FILE" ] && [ -f "$FRAMEWORK_DIR/shared/golden_evals_base.json" ]; then
  cp "$FRAMEWORK_DIR/shared/golden_evals_base.json" "$GOLDEN_FILE"
  echo "✅ Seeded baseline golden dataset"
fi

# Seed judge criteria
CRITERIA_FILE="$REPO_ROOT/.agent-rfc/fixtures/custom_judge_criteria.json"
if [ ! -f "$CRITERIA_FILE" ] && [ -f "$FRAMEWORK_DIR/shared/custom_judge_criteria_base.json" ]; then
  cp "$FRAMEWORK_DIR/shared/custom_judge_criteria_base.json" "$CRITERIA_FILE"
  echo "✅ Seeded baseline judge criteria"
fi

# ── Seed .agent-rfc/security/ pack from framework templates ──────────────────
# The SEC-* harness looks for these four artifacts in every tenant repo, but
# nothing used to put them there — so a new tenant started with those controls
# skipping/failing and had to discover fixtures/security/templates/ by reading
# the framework tree (TestbedFeedback-2026-07-21 G5).
#
# Seeded, never overwritten: a filled-in risk register is the tenant's own
# document (its content is exactly what the framework CANNOT know), so a
# later checkout must never clobber it. Same guard as the golden dataset.
SECURITY_TEMPLATES="$FRAMEWORK_DIR/shared/security"
if [ -d "$SECURITY_TEMPLATES" ]; then
  mkdir -p "$REPO_ROOT/.agent-rfc/security"
  SEEDED_SECURITY=0
  for TEMPLATE in "$SECURITY_TEMPLATES"/*.yaml; do
    [ -f "$TEMPLATE" ] || continue
    TARGET="$REPO_ROOT/.agent-rfc/security/$(basename "$TEMPLATE")"
    if [ ! -f "$TARGET" ]; then
      cp "$TEMPLATE" "$TARGET"
      SEEDED_SECURITY=$((SEEDED_SECURITY + 1))
    fi
  done
  if [ "$SEEDED_SECURITY" -gt 0 ]; then
    echo "✅ Seeded $SEEDED_SECURITY security artifact(s) into .agent-rfc/security/"
    echo "   ⚠️  These are PLACEHOLDERS — edit them before promoting to production:"
    echo "      risk_register.yaml   your real residual risks and owners"
    echo "      agency_manifest.yaml your high-impact actions requiring HITL"
    echo "      tool_allowlist.yaml  your registered tool names (deny-by-default)"
    echo "      nist_profile.yaml    your org name and control owners"
    echo "   Verify with: python3 scripts/run-security-checks.py --mode ci --strict"
  fi
fi

# ── Resolve project name and owner ────────────────────────────────────────────
PROJECT_NAME=$(git remote get-url origin 2>/dev/null | sed 's/.*\///' | sed 's/\.git$//' || basename "$REPO_ROOT")
OWNER_ID="${AGENT_OWNER_ID:-unknown@unknown}"
OTEL_ENDPOINT="${AGENT_PHOENIX_ENDPOINT:-http://localhost:6006}"

# ── Generate .cursorrules / CLAUDE.md / Antigravity skills ───────────────────
# Single source of truth: templates/agent-rules.yaml (SPECS.md §4, §13, §22
# Phase 5). Never edit .cursorrules/CLAUDE.md/.agents/skills/ directly or add
# new IDE-rule content as inline heredocs here — edit agent-rules.yaml.
RULES_FILE="$FRAMEWORK_DIR/templates/agent-rules.yaml"
case "$STACK" in
  TS_REACT)       RULES_STACK_KEY="ts-react" ;;
  PYTHON_FASTAPI) RULES_STACK_KEY="python-fastapi" ;;
  GO)             RULES_STACK_KEY="go" ;;
  *)              RULES_STACK_KEY="generic" ;;
esac

GEN_SCRIPT="$REPO_ROOT/scripts/generate-ide-config.py"
[ ! -f "$GEN_SCRIPT" ] && GEN_SCRIPT="$SCRIPTS_DIR/generate-ide-config.py"

if [ -f "$RULES_FILE" ] && [ -f "$GEN_SCRIPT" ]; then
  python3 "$GEN_SCRIPT" \
    --repo-root "$REPO_ROOT" \
    --rules-file "$RULES_FILE" \
    --stack "$RULES_STACK_KEY" \
    --project-name "$PROJECT_NAME" \
    --owner-id "$OWNER_ID" \
    --otel-endpoint "$OTEL_ENDPOINT" \
    --test-cmd "$TEST_CMD" \
    --framework-version "${FRAMEWORK_VERSION:-1.0.0}" || \
    echo "⚠️  IDE config generation failed — see error above. .cursorrules/CLAUDE.md/.agents/skills/ not written."
else
  echo "⚠️  agent-rules.yaml or generate-ide-config.py not found — IDE config not generated. Re-run install-ai-stack.sh."
fi

# ── GitHub Actions — copy from workflow-templates (single source, SPECS.md §17) ─
# Same templates ai-tenant-init uses — no inline heredocs here (they drifted).
TMPL_DIR="$FRAMEWORK_DIR/workflow-templates"
GITHUB_WF="$REPO_ROOT/.github/workflows"

TENANT_ID=""
if [ -f "$REPO_ROOT/.agenticframework/tenant.yaml" ]; then
  TENANT_ID="$(grep '^  id:' "$REPO_ROOT/.agenticframework/tenant.yaml" | head -1 | sed 's/^  id:[[:space:]]*//')"
fi
if [ -z "$TENANT_ID" ]; then
  TENANT_ID="$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//')"
fi
if ! [[ "$TENANT_ID" =~ ^[a-z0-9-]+$ ]] || [ -z "$TENANT_ID" ]; then
  TENANT_ID="project"
fi

WF_CI=""
case "$STACK" in
  TS_REACT)       WF_CI="ci-ts-react.yml" ;;
  PYTHON_FASTAPI) WF_CI="ci-python-fastapi.yml" ;;
  GO)             WF_CI="ci-go.yml" ;;
esac

if [ -f "$GITHUB_WF/cd-deploy.yml" ]; then
  echo "⚠️  Legacy cd-deploy.yml found — remove it and use cd-staging.yml + cd-production.yml (OPERATIONS.md §C)."
fi

if [ -d "$TMPL_DIR" ] && [ -n "$WF_CI" ]; then
  mkdir -p "$GITHUB_WF"
  # eval-fairness/eval-hallucination/eval-ttft-live are referenced by every
  # ci-<stack>.yml as `uses: ./.github/workflows/<name>` — a missing callee
  # makes GitHub reject the whole CI workflow as invalid, so they ship
  # together with the caller.
  for wf in "$WF_CI" "cd-staging.yml" "cd-production.yml" "eval-scorecard.yml" \
            "eval-fairness.yml" "eval-hallucination.yml" "eval-ttft-live.yml"; do
    src="$TMPL_DIR/$wf"
    dest="$GITHUB_WF/$wf"
    if [ ! -f "$src" ]; then
      echo "⚠️  Workflow template missing, skipping: $src"
      continue
    fi
    if [ -f "$dest" ]; then
      continue
    fi
    sed "s/{{TENANT_ID}}/${TENANT_ID}/g" "$src" > "$dest"
    echo "✅ Written $dest (from workflow-templates)"
  done

  # Composite actions the cd-* workflows call as `uses: ./.github/actions/<name>`
  # — resolved inside THIS repo, so they must be copied in alongside the
  # workflows (vendored to ~/.agent-framework/github-actions/ by the installer).
  ACTIONS_SRC="$FRAMEWORK_DIR/github-actions"
  if [ -d "$ACTIONS_SRC" ] && [ "$(ls -A "$ACTIONS_SRC" 2>/dev/null)" ]; then
    mkdir -p "$REPO_ROOT/.github/actions"
    for action_dir in "$ACTIONS_SRC"/*/; do
      [ -d "$action_dir" ] || continue
      action_name="$(basename "$action_dir")"
      if [ -d "$REPO_ROOT/.github/actions/$action_name" ]; then
        continue
      fi
      cp -r "$action_dir" "$REPO_ROOT/.github/actions/$action_name"
      echo "✅ Written .github/actions/$action_name (from github-actions)"
    done
  else
    echo "⚠️  ~/.agent-framework/github-actions/ missing — cd-staging/cd-production reference ./.github/actions/* and will fail. Re-run install-ai-stack.sh."
  fi
elif [ "$STACK" != "GENERIC" ] && [ ! -d "$TMPL_DIR" ]; then
  echo "⚠️  workflow-templates not installed — run install-ai-stack.sh. CI/CD workflows not written."
fi

# ── Update Knowledge Graph ────────────────────────────────────────────────────
# AGENT_KG_DEFER=1 skips the rebuild during batch git operations — see
# hooks/post-commit for the full rationale (ReviewFindings-2026-07-18 C2).
if [ "${AGENT_KG_DEFER:-0}" != "1" ]; then
  MAP_SCRIPT="$REPO_ROOT/scripts/map_codebase.py"
  [ ! -f "$MAP_SCRIPT" ] && MAP_SCRIPT="$SCRIPTS_DIR/map_codebase.py"
  if [ -f "$MAP_SCRIPT" ]; then
    python3 "$MAP_SCRIPT" 2>/dev/null && echo "✅ Knowledge Graph seeded" || true
  fi
fi

# ── .gitignore for public repos ───────────────────────────────────────────────
REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "")
IS_PUBLIC=0

# Real visibility via `gh` when available (SPECS.md §20); if gh is missing,
# unauthenticated, or the lookup fails, fall back to treating any github.com
# remote as potentially public — the safe direction, since the consequence
# is only a .gitignore prompt (or a conservative auto-append in CI).
if echo "$REMOTE_URL" | grep -q "github.com"; then
  IS_PUBLIC=1
  if command -v gh >/dev/null 2>&1; then
    REPO_SLUG=$(echo "$REMOTE_URL" | sed -E 's#^(git@github\.com:|https://github\.com/)##; s#\.git$##')
    VISIBILITY=$(gh repo view "$REPO_SLUG" --json visibility --jq .visibility 2>/dev/null || echo "")
    case "$VISIBILITY" in
      PRIVATE|private|INTERNAL|internal) IS_PUBLIC=0 ;;
    esac
  fi
fi

if [ "$IS_PUBLIC" -eq 1 ] && [ -t 1 ]; then
  echo ""
  echo "⚠️  This repository appears to be public."
  echo "   .cursorrules, CLAUDE.md, and .agents/ contain system prompt content."
  read -r -p "   Add them to .gitignore? (y/n): " GITIGNORE_CHOICE
  if [[ "${GITIGNORE_CHOICE:-y}" =~ ^[Yy]$ ]]; then
    GITIGNORE="$REPO_ROOT/.gitignore"
    {
      echo ""
      echo "# AgentSmith — IDE configs (system prompt content)"
      echo ".cursorrules"
      echo "CLAUDE.md"
      echo ".agents/"
      echo ".agent-history.log"
    } >> "$GITIGNORE"
    echo "✅ Added IDE config files to .gitignore"
  fi
elif [ "$IS_PUBLIC" -eq 1 ]; then
  # Non-interactive (CI): auto-add to .gitignore
  GITIGNORE="$REPO_ROOT/.gitignore"
  {
    echo ""
    echo "# AgentSmith — IDE configs (system prompt content)"
    echo ".cursorrules"
    echo "CLAUDE.md"
    echo ".agents/"
    echo ".agent-history.log"
  } >> "$GITIGNORE"
fi

# ── Write the developer opt-in marker (FIXES_AND_CLEANUP.md P1a) ────────────
# Reached only for a brand-new `git init` (no HEAD) or an already-opted-in
# repo — the gate at the top of this hook skips pre-existing repos that
# never opted in, so a totally unrelated repo someone just `git clone`'d is
# never provisioned or opted in behind their back. Writing the marker here
# is what makes pre-commit/commit-msg/post-commit enforce in THIS repo from
# now on (they no-op without it), exactly as documented in UserManual.md §3.
if [ ! -f "$REPO_ROOT/.agenticframework/enabled" ] && [ ! -f "$REPO_ROOT/.agenticframework/tenant.yaml" ]; then
  mkdir -p "$REPO_ROOT/.agenticframework"
  touch "$REPO_ROOT/.agenticframework/enabled"
fi

echo ""
echo "✅ AgentSmith: Project provisioned for [$STACK] — $(basename "$REPO_ROOT")"
exit 0
