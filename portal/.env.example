# Ops Portal configuration (SPECS.md §15, §26)

# Same Postgres instance used by runtime/llm_gateway.py's budget backend
DATABASE_URL=postgresql://phoenix:phoenix@localhost:5432/phoenix

# Dashboard basic auth — required, the portal refuses to serve without these
OPS_PORTAL_USER=ops
OPS_PORTAL_PASSWORD=change-me

# Bearer token tenant CD pipelines use to POST /api/sync/history
OPS_PORTAL_SYNC_TOKEN=change-me-too

# Audit log (SPECS.md §30, enterprise pack) — append-only, HMAC-signed
AUDIT_LOG_WRITE_TOKEN=change-me-three
AUDIT_LOG_HMAC_KEY=change-me-four-this-one-especially

# SSO/OIDC (SPECS.md §30, enterprise pack) — set SSO_ENABLED=true to REPLACE
# basic auth above with OIDC login. Leave SSO_ENABLED unset/false to keep
# using OPS_PORTAL_USER/PASSWORD (the default, non-enterprise setup).
# SSO_ENABLED=true
# SSO_ISSUER=https://corp.okta.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_REDIRECT_URI=https://ops.example.com/api/auth/callback
# SSO_SESSION_SECRET=
# SSO_ALLOW_INSECURE_HTTP=false  # local dev/test against a non-TLS IdP ONLY
